# === CricketPulse Configuration ===
# Copy this file to .env and fill in your values

# --- GenAI ---
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_BALLS=balls.raw
KAFKA_TOPIC_PREDICTIONS=balls.predictions
KAFKA_CONSUMER_GROUP=cricketpulse-consumer

# --- Warehouse ---
DUCKDB_PATH=data/warehouse/cricketpulse.duckdb

# --- Match simulation ---
# Seconds between balls (lower = faster demo, higher = more realistic)
BALL_INTERVAL_SECONDS=1.5
# Default teams for a fresh match (any two IPL-style names)
TEAM_A=Mumbai Mavericks
TEAM_B=Chennai Chargers
VENUE=Wankhede Stadium
